<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Honey liquid layer - partially filling the bottom half -->
    <path
        android:pathData="M6.7,70 L50,95 L93.3,70 L93.3,55 C93.3,55 80,45 65,52 C50,59 35,48 20,55 C10,59 6.7,55 6.7,55 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="50"
                android:startY="50"
                android:endX="50"
                android:endY="95"
                android:type="linear">
                <item android:offset="0" android:color="#FFF59D" /> <!-- Pale Yellow -->
                <item android:offset="1" android:color="#FBC02D" /> <!-- Honey Gold -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Honey drip (Overflow effect) -->
    <path
        android:pathData="M40,90 Q45,105 50,95 Q55,105 60,90"
        android:strokeColor="#FBC02D"
        android:strokeWidth="2"
        android:strokeLineCap="round" />

    <path
        android:pathData="M42,92 C42,100 48,100 48,92"
        android:fillColor="#FBC02D" />

</vector>
